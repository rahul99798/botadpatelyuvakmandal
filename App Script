    }

    const data = sheet.getDataRange().getValues();
    let found = false;

    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === "achievementEnabled") {
        sheet.getRange(i + 1, 2).setValue(String(newStatus));
        found = true;
        break;
      }
    }

    if (!found) {
      sheet.appendRow(["achievementEnabled", String(newStatus)]);
    }

    return { status: "success" };
  } catch (e) {
    Logger.log('toggleAchievementStatus Error: ' + e);
    return { status: "error" };
  }
}

function getMembersWithResults() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sh = ss.getSheetByName('Result');
    if (!sh) return [];

    var data = sh.getDataRange().getValues();
    var members = new Map(); // memberNo → full name

    // A = MemberNo, B = Mobile, F onwards blocks
    for (var i = 1; i < data.length; i++) {   // row 2 થી શરૂ
      var memberNo = String(data[i][0] || '').trim();
      if (!memberNo) continue;

      // Check if this row has at least one result block
      var hasResult = false;
      var blockStarts = [5, 13, 21, 29, 37, 45, 53, 61, 69, 77]; // F, N, V ...

      for (var b = 0; b < blockStarts.length; b++) {
        var col = blockStarts[b];
        if (String(data[i][col] || '').trim() !== '') {
          hasResult = true;
          break;
        }
      }

      if (hasResult) {
        // Sabhy Details sheet માંથી નામ લઈ લો
        var name = getMemberFullName(memberNo);
        members.set(memberNo, name || "Unknown (" + memberNo + ")");
      }
    }

    // Array માં કન્વર્ટ કરો અને sort કરો
    var resultList = [];
    members.forEach((name, memberNo) => {
      const cleanName = (name || "Unknown").trim();
      const cleanNo   = String(memberNo || "").trim();
      
      resultList.push({ 
        memberNo: cleanNo, 
        name: cleanName,
        display: `${cleanNo} - ${cleanName}`   // ← આ લાઇન બદલી (પહેલા નંબર)
      });
    });

    // નામ મુજબ sort (ગુજરાતીમાં સારી રીતે sort થાય)
      resultList.sort((a, b) => (parseInt(a.memberNo) || 0) - (parseInt(b.memberNo) || 0));

