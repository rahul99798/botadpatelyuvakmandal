    if (!mobile || !sabhyaNo || !base64) {
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'Missing mobile, sabhyaNo, or image',
      });
    }


    if (
      !MEMBER_PHOTO_FOLDER_ID ||
      MEMBER_PHOTO_FOLDER_ID.indexOf('YOUR_DRIVE') === 0
    ) {
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'MEMBER_PHOTO_FOLDER_ID સેટ કરો.',
      });
    }


    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sh = ss.getSheetByName(MEMBER_SHEET_NAME);
    if (!sh) {
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'Sabhy Details sheet not found',
      });
    }


    var rowIndex = findRowBySabhyaNo_(sh, sabhyaNo);
    if (!rowIndex) {
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'સભ્ય નંબર મળ્યો નથી.',
      });
    }


    if (MOBILE_COL > 0) {
      var rowMobile = String(
        sh.getRange(rowIndex, MOBILE_COL).getValue() || '',
      ).replace(/\D/g, '');
      var reqMobile = mobile.replace(/\D/g, '');
      if (rowMobile !== reqMobile) {
        return memberPhotoJsonOut_({
          status: 'error',
          message: 'મોબાઈલ નંબર મેળ ખાતો નથી.',
        });
      }
    }


    var blob;
    try {
      blob = Utilities.newBlob(
        Utilities.base64Decode(base64),
        mime,
        'sabhya_' + sabhyaNo + '_' + fileName,
      );
    } catch (err) {
      return memberPhotoJsonOut_({ status: 'error', message: 'Invalid image data' });
    }


    var folder = DriveApp.getFolderById(MEMBER_PHOTO_FOLDER_ID);
    var file;
    try {
      file = folder.createFile(blob);
      // Workspace એડમિન "Anyone with link" બંધ કરે તો setSharing નિષ્ફળ → પહેલાં આખું અપલોડ ફેલ લાગતું.
      // ફાઇલ ફોલ્ડરમાં બની ગયા પછી શેરિંગ નિષ્ફળ હોય તો પણ શીટ સેવ ચાલુ રાખો (ફોલ્ડર પહેલેથી શેર હોય તો લિંક ચાલી શકે).
