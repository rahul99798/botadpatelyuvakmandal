  function handleResultSave_(data) {
    try {
      Logger.log('🎯 handleResultSave_ શરૂ થયું');


      var mobile = String(data.mobile || '').trim();
      var memberNo = String(data.memberNo || '').trim();
      var studentName = String(data.studentName || '').trim();
      var standard = String(data.standard || '').trim();
      var percentage = String(data.percentage || '').trim();
      var year = String(data.year || '').trim();
     
      // 🔥 હવે files એક array છે: [{base64, mime, fileName}, ...]
      var files = data.files || [];


      Logger.log('Student=' + studentName + ' | Year=' + year + ' | Files count=' + files.length);


      if (!mobile || !studentName || !standard || !percentage || !year) {
        return memberPhotoJsonOut_({
          status: 'error',
          message: 'બધી વિગતો ભરો.',
        });
      }


      var ss = SpreadsheetApp.getActiveSpreadsheet();
      var sh = ss.getSheetByName('Result');
      if (!sh) {
        return memberPhotoJsonOut_({
          status: 'error',
          message: 'Result sheet મળી નથી.',
        });
      }


      // ========= STEP 1: Row શોધો =========
      var lastRow = sh.getLastRow();
      var rowIndex = null;
      var cleanMobile = mobile.replace(/\D/g, '');
      var cleanMemberNo = memberNo.replace(/\D/g, '');


      if (lastRow >= 2) {
        var abData = sh.getRange(2, 1, lastRow - 1, 2).getValues();
        for (var i = 0; i < abData.length; i++) {
          var rowMemberNo = String(abData[i][0] || '').replace(/\D/g, '');
          var rowMobile = String(abData[i][1] || '').replace(/\D/g, '');
          if (rowMobile && rowMobile === cleanMobile) { rowIndex = i + 2; break; }
          if (cleanMemberNo && rowMemberNo && rowMemberNo === cleanMemberNo) { rowIndex = i + 2; break; }
        }
      }


      if (!rowIndex) {
        rowIndex = lastRow < 1 ? 2 : lastRow + 1;
        if (memberNo) {
          sh.getRange(rowIndex, 1).setNumberFormat('@');
          sh.getRange(rowIndex, 1).setValue(memberNo);
        }
        sh.getRange(rowIndex, 2).setNumberFormat('@');
        sh.getRange(rowIndex, 2).setValue(mobile);
        SpreadsheetApp.flush();
      }


      // ========= STEP 2: Block શોધો (same student+year → update) =========
      var blockStartCols = [6, 14, 22, 30, 38, 46, 54, 62, 70, 78];
      var targetCol = null;
      var isUpdate = false;
      var cleanStudentName = studentName.toLowerCase().replace(/\s+/g, ' ').trim();
      var cleanYear = year.trim();


      for (var b = 0; b < blockStartCols.length; b++) {
        var checkCol = blockStartCols[b];
        var existingName = String(sh.getRange(rowIndex, checkCol).getValue() || '').toLowerCase().replace(/\s+/g, ' ').trim();
        var existingYear = String(sh.getRange(rowIndex, checkCol + 3).getValue() || '').trim();
       
        if (existingName && existingName === cleanStudentName && existingYear === cleanYear) {
          targetCol = checkCol;
          isUpdate = true;
          Logger.log('🔄 UPDATE block at col ' + checkCol);
          break;
        }
      }


      if (!targetCol) {
        for (var b = 0; b < blockStartCols.length; b++) {
          var checkCol = blockStartCols[b];
          var existing = sh.getRange(rowIndex, checkCol).getValue();
          if (!existing || String(existing).trim() === '') {
            targetCol = checkCol;
            break;
          }
        }
      }


      if (!targetCol) {
        return memberPhotoJsonOut_({
          status: 'error',
          message: 'આ સભ્યના બધા 10 blocks ભરાઈ ગયા છે.',
        });
      }


      // ========= STEP 3: Files Upload =========
      var uploadedUrls = [];
      var oldUrls = '';


      if (isUpdate) {
        oldUrls = String(sh.getRange(rowIndex, targetCol + 4).getValue() || '').trim();
      }


      if (files && files.length > 0) {
        // નવી files આપી છે - upload કરો
        var folder = DriveApp.getFolderById(RESULT_PHOTO_FOLDER_ID);
        var safeStudentName = studentName.replace(/[\\/:*?"<>|]/g, '').trim();


        for (var f = 0; f < files.length; f++) {
          try {
            var file = files[f];
            if (!file.base64) continue;


            var mime = file.mime || 'image/jpeg';
            var origName = file.fileName || ('file_' + (f + 1));
            var extension = 'jpg';
            if (origName && origName.indexOf('.') > -1) {
              extension = origName.split('.').pop().toLowerCase();
            } else if (mime === 'application/pdf') {
              extension = 'pdf';
            }


            var customFileName = (memberNo || 'X') + '_' + mobile + '_' + standard + '_' + safeStudentName + '_' + (f + 1) + '.' + extension;


            var blob = Utilities.newBlob(Utilities.base64Decode(file.base64), mime, customFileName);
            var driveFile = folder.createFile(blob);
            try {
              driveFile.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
            } catch (shareErr) {
              Logger.log('setSharing skipped: ' + shareErr);
            }


            // PDF અને images માટે URL format અલગ
            var fileId = driveFile.getId();
            var url;
            if (mime === 'application/pdf' || extension === 'pdf') {
              // PDF માટે direct preview link
              url = 'https://drive.google.com/file/d/' + fileId + '/view';
            } else {
              url = 'https://lh3.googleusercontent.com/d/' + fileId;
            }


            uploadedUrls.push(url);
            Logger.log('✅ File ' + (f + 1) + ' uploaded: ' + url);
          } catch (fileErr) {
            Logger.log('⚠️ File ' + (f + 1) + ' failed: ' + fileErr);
          }
        }


        // જૂની files trash કરો (update case)
        if (isUpdate && oldUrls) {
          var oldList = oldUrls.split('|').filter(function(u){ return u.trim() !== ''; });
          for (var o = 0; o < oldList.length; o++) {
            try {
              var oldId = oldList[o].match(/\/d\/([^\/\?]+)/);
              if (oldId && oldId[1]) {
                DriveApp.getFileById(oldId[1]).setTrashed(true);
              }
            } catch (delErr) {
              Logger.log('Old file delete skipped: ' + delErr);
            }
          }
        }
      } else if (isUpdate && oldUrls) {
        // નવી files નથી, update છે - જૂની જ રાખો
        Logger.log('📌 જૂની files જ રાખી');
      }


      // Final URL string - pipe (|) થી separate
      var finalUrlString;
      if (uploadedUrls.length > 0) {
        finalUrlString = uploadedUrls.join('|');
      } else if (isUpdate) {
        finalUrlString = oldUrls; // જૂની રાખો
      } else {
        finalUrlString = '';
      }


      // ========= STEP 4: Data લખો =========
      var now = new Date();
      var dateTime = Utilities.formatDate(now, Session.getScriptTimeZone(), 'dd-MM-yyyy HH:mm:ss');


      try {
        sh.getRange(rowIndex, targetCol).setValue(studentName);
        sh.getRange(rowIndex, targetCol + 1).setValue(standard);
        sh.getRange(rowIndex, targetCol + 2).setValue(percentage);
        sh.getRange(rowIndex, targetCol + 3).setValue(year);
        sh.getRange(rowIndex, targetCol + 4).setValue(finalUrlString);
        sh.getRange(rowIndex, targetCol + 5).setValue(dateTime);
        SpreadsheetApp.flush();
      } catch (writeErr) {
        return memberPhotoJsonOut_({
          status: 'error',
          message: 'શીટમાં લખવામાં ભૂલ: ' + String(writeErr),
        });
      }


      return memberPhotoJsonOut_({
        status: 'success',
        message: isUpdate ? 'જૂનું રિઝલ્ટ અપડેટ થયું ✅' : 'નવું રિઝલ્ટ સેવ થયું ✅',
        filesUploaded: uploadedUrls.length,
        isUpdate: isUpdate,
      });


    } catch (e) {
      Logger.log('❌ FATAL: ' + e + ' | ' + e.stack);
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'સર્વર ભૂલ: ' + String(e),
      });
    }
  }


  function getResults(mobile, memberNo) {
    try {
      var ss = SpreadsheetApp.getActiveSpreadsheet();
      var sh = ss.getSheetByName('Result');
      if (!sh) return [];


      var lastRow = sh.getLastRow();
      if (lastRow < 2) return [];


      var cleanMobile = String(mobile || '').replace(/\D/g, '');
      var cleanMemberNo = String(memberNo || '').replace(/\D/g, '');


      // Column A=MemberNo, B=Mobile, F થી blocks
      // એક row ના બધા columns વાંચો (max 83 columns - 10 blocks સુધી)
      var data = sh.getRange(2, 1, lastRow - 1, 83).getValues();


      var results = [];
      for (var i = 0; i < data.length; i++) {
        var rowMemberNo = String(data[i][0] || '').replace(/\D/g, '');
        var rowMobile = String(data[i][1] || '').replace(/\D/g, '');


        // Mobile અથવા MemberNo match થાય તો જ આ row ના results લો
        var matched = false;
        if (cleanMobile && rowMobile === cleanMobile) matched = true;
        if (!matched && cleanMemberNo && rowMemberNo === cleanMemberNo) matched = true;


        if (!matched) continue;


        // Block start: F(index 5), N(13), V(21), AD(29), AL(37), AT(45), BB(53), BJ(61), BR(69), BZ(77)
        var blockStarts = [5, 13, 21, 29, 37, 45, 53, 61, 69, 77];


        for (var b = 0; b < blockStarts.length; b++) {
          var s = blockStarts[b];
          var name = String(data[i][s] || '').trim();
          if (!name) continue; // ખાલી block skip


          results.push({
            studentName: name,
            standard: String(data[i][s + 1] || '').trim(),
            percentage: String(data[i][s + 2] || '').trim(),
            year: String(data[i][s + 3] || '').trim(),
            photo: String(data[i][s + 4] || '').trim(),
            dateTime: String(data[i][s + 5] || '').trim(),
          });
        }
      }


      return results;
    } catch (e) {
      Logger.log('getResults error: ' + e);
      return [];
    }
  }


  function getAchievements(memberNo) {
  try {
    var sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Achievements');
    if (!sh) return [];


    var data = sh.getDataRange().getValues();
    var results = [];


    var searchMemberNo = String(memberNo || '').trim();


    for (var i = 1; i < data.length; i++) {
      var rowMemberNo = String(data[i][0] || '').trim();   // Column A


      if (rowMemberNo === searchMemberNo) {


        var blocks = [
          { name: 4, mobile: 5, year: 6, desc: 7, photo: 8 },   // E to I
          { name:10, mobile:11, year:12, desc:13, photo:14 },   // K to O
          { name:16, mobile:17, year:18, desc:19, photo:20 }    // Q to U
        ];


        for (var b = 0; b < blocks.length; b++) {
          var blk = blocks[b];


          var nameVal   = String(data[i][blk.name]   || '').trim();
          var mobileVal = String(data[i][blk.mobile] || '').trim();
          var yearVal   = String(data[i][blk.year]   || '').trim();
          var descVal   = String(data[i][blk.desc]   || '').trim();
          var photoVal  = String(data[i][blk.photo]  || '').trim();


          // જો નામ હોય તો જ ઉમેરો
          if (nameVal !== "") {
            results.push({
              studentName: nameVal,
              mobile: mobileVal || "-",        // F કોલમ
              year: yearVal || "-",            // G કોલમ
              description: descVal || "",      // H કોલમ
              photo: photoVal                  // I કોલમ
            });
          }
        }
      }
    }


    // સૌથી નવું ઉપર આવે તે માટે reverse
    results.reverse();


    return results;


  } catch(e) {
    Logger.log('getAchievements Error: ' + e);
    return [];
  }
