function handleFamilyPhotoUpload_(data) {
  try {
    var mainMobile = String(data.mainMemberMobile || '').trim();
    var familyMobile = String(data.familyMobile || '').trim();
    var base64 = data.base64;
    var mime = data.mimeType || 'image/jpeg';
    var fileName = data.fileName || 'family.jpg';

    if (!mainMobile || !familyMobile || !base64) {
      return memberPhotoJsonOut_({ status: 'error', message: 'વિગતો અધૂરી છે.' });
    }

    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sh = ss.getSheetByName(MEMBER_SHEET_NAME);
    if (!sh) {
      return memberPhotoJsonOut_({ status: 'error', message: 'Sabhy Details sheet મળી નથી.' });
    }

    var cleanMainMobile = mainMobile.replace(/\D/g, '');
    var cleanFamilyMobile = familyMobile.replace(/\D/g, '');

    // 🎯 STEP 1: મુખ્ય સભ્યની row શોધો
    var lastRow = sh.getLastRow();
    var rowIndex = null;
    for (var i = 2; i <= lastRow; i++) {
      var rowMobile = String(sh.getRange(i, 1).getValue() || '').replace(/\D/g, '');
      if (rowMobile === cleanMainMobile) {
        rowIndex = i;
        break;
      }
    }

    if (!rowIndex) {
      return memberPhotoJsonOut_({ status: 'error', message: 'મુખ્ય સભ્ય મળ્યા નથી.' });
    }

    // 🎯 STEP 2: પરિવારના સભ્યનો block શોધો
// 🎯 STEP 2: પરિવારના સભ્યનો block — index આધારે સીધી ગણતરી
    var familyIndex = parseInt(data.familyIndex);
    if (isNaN(familyIndex) || familyIndex < 0) {
      return memberPhotoJsonOut_({ status: 'error', message: 'સભ્યનો ક્રમ મળ્યો નથી.' });
    }

    var familyStartCol = 22 + (familyIndex * 12);   // 1-based
    var photoCol = familyStartCol + 10;
    var familyFirstName = String(sh.getRange(rowIndex, familyStartCol).getValue() || '').trim();

    if (!familyFirstName) {
      return memberPhotoJsonOut_({ status: 'error', message: 'આ ક્રમ પર પરિવાર સભ્ય નથી.' });
    }

    // 🎯 મુખ્ય સભ્ય નંબર (MemberNo) મેળવો — column D
    var memberNo = String(sh.getRange(rowIndex, 4).getValue() || '').trim();

    // 🎯 STEP 3: ફાઇલ નામ બનાવો — SabhyaNo_Mobile_FirstName.ext
    var extension = 'jpg';
    if (fileName && fileName.indexOf('.') > -1) {
      extension = fileName.split('.').pop().toLowerCase();
    } else if (mime === 'image/png') {
      extension = 'png';
    } else if (mime === 'image/webp') {
      extension = 'webp';
    }

    var safeName = familyFirstName.replace(/[\\/:*?"<>|]/g, '').trim();
    var customFileName = (memberNo || 'X') + '_' + cleanFamilyMobile + '_' + safeName + '.' + extension;

    // 🎯 STEP 4: Blob બનાવો
    var blob;
    try {
      blob = Utilities.newBlob(
        Utilities.base64Decode(base64),
        mime,
        customFileName
      );
    } catch (err) {
      return memberPhotoJsonOut_({ status: 'error', message: 'Invalid image data' });
    }

    // 🎯 STEP 5: Drive માં અપલોડ
    var folder = DriveApp.getFolderById("1YX5q124yM_ZPo2ac8dh7mf0K6WO2-sw0");
    var file;
    try {
      file = folder.createFile(blob);
      try {
        file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
      } catch (shareErr) {
        Logger.log('setSharing skipped: ' + shareErr);
      }
    } catch (driveErr) {
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'Drive અપલોડ ભૂલ: ' + String(driveErr)
      });
    }

    var photoUrl = 'https://lh3.googleusercontent.com/d/' + file.getId();

    // 🎯 STEP 6: Sheet માં URL લખો
    try {
      sh.getRange(rowIndex, photoCol).setNumberFormat('@');
      sh.getRange(rowIndex, photoCol).setValue(photoUrl);
      SpreadsheetApp.flush();
    } catch (sheetErr) {
      try { file.setTrashed(true); } catch(e){}
      return memberPhotoJsonOut_({
        status: 'error',
        message: 'શીટમાં લખવામાં ભૂલ: ' + String(sheetErr)
      });
    }

    return memberPhotoJsonOut_({
      status: 'success',
      photoUrl: photoUrl,
      message: 'ફોટો સેવ થયો ✅'
    });

  } catch (err) {
    Logger.log('handleFamilyPhotoUpload_ Error: ' + err);
    return memberPhotoJsonOut_({ status: 'error', message: 'સર્વર ભૂલ: ' + String(err) });
  }
}
