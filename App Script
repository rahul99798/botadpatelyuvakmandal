 function handleAchievementSave_(data) {
  try {
    var memberNo     = String(data.memberNo || '').trim();
    var aMobile      = String(data.aMobile || '').trim();        // મુખ્ય સભ્યનો મોબાઈલ
    var inputMobile  = String(data.inputMobile || '').trim();    // વિદ્યાર્થીનો મોબાઈલ (F કોલમ)
    var studentName  = String(data.studentName || '').trim();
    var year         = String(data.year || '').trim();
    var description  = String(data.description || '').trim();
    var files        = data.files || [];


    if (!memberNo || !aMobile || !studentName || !year || !description) {
      return ContentService.createTextOutput(JSON.stringify({
        status: 'error',
        message: 'સભ્ય નંબર, મોબાઈલ, વ્યક્તિનું નામ, વર્ષ અને વર્ણન જરૂરી છે.'
      })).setMimeType(ContentService.MimeType.JSON);
    }


    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sh = ss.getSheetByName('Achievements');
    if (!sh) {
      return ContentService.createTextOutput(JSON.stringify({
        status: 'error',
        message: 'Achievements sheet મળી નથી.'
      })).setMimeType(ContentService.MimeType.JSON);
    }


    // ================= FILES UPLOAD =================
    var photoUrls = [];
    if (files.length > 0) {
      var folder = DriveApp.getFolderById(ACHIEVEMENT_PHOTO_FOLDER_ID);


      for (var i = 0; i < files.length; i++) {
        var f = files[i];
        if (!f.base64) continue;


        var mime = f.mime || 'image/jpeg';
        var origName = f.fileName || 'ach.jpg';
        var extension = 'jpg';


        // Extension નક્કી કરો
        if (origName && origName.indexOf('.') > -1) {
          extension = origName.split('.').pop().toLowerCase();
        } else if (mime === 'application/pdf') {
          extension = 'pdf';
        }


        // 🔥 તમારી જોઈતી ફાઈલ નેમિંગ: sabhyaNo_mobile_Year_studentName.ext
        var safeStudentName = studentName.replace(/[\\/:*?"<>|]/g, '_').trim(); // special chars replace
        var customFileName = memberNo + '_' +
                             aMobile + '_' +
                             year + '_' +
                             safeStudentName +
                             '.' + extension;


        var blob = Utilities.newBlob(
          Utilities.base64Decode(f.base64),
          mime,
          customFileName
        );


        var driveFile = folder.createFile(blob);
        try {
          driveFile.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
        } catch(e){}


        var fileId = driveFile.getId();
        var url = (mime && mime.includes('pdf')) || extension === 'pdf'
          ? 'https://drive.google.com/file/d/' + fileId + '/view'
          : 'https://lh3.googleusercontent.com/d/' + fileId;


        photoUrls.push(url);
      }
    }
    var photoUrlString = photoUrls.join('|');


    // ================= ROW શોધવી =================
    var lastRow = sh.getLastRow();
    var targetRow = null;


    if (lastRow >= 2) {
      var checkData = sh.getRange(2, 1, lastRow - 1, 3).getValues(); // A, B, C
      for (var i = 0; i < checkData.length; i++) {
        if (String(checkData[i][0] || '').trim() === memberNo &&
            String(checkData[i][2] || '').trim() === aMobile) {
          targetRow = i + 2;
          break;
        }
      }
    }


    if (!targetRow) {
      return ContentService.createTextOutput(JSON.stringify({
        status: 'error',
        message: 'મુખ્ય સભ્યની રો મળી નથી.'
      })).setMimeType(ContentService.MimeType.JSON);
    }


    // ================= ડાયનેમિક બ્લોક્સ =================
    var startCols = [5, 11, 17, 23, 29, 35, 41, 47, 53, 59, 65, 71, 77, 83, 89, 95];


    var targetBlock = null;
    var isUpdate = false;


    // 1. એ જ Student Name + એ જ Year હોય તો Update
    for (var b = 0; b < startCols.length; b++) {
      var col = startCols[b];
      var existingName = String(sh.getRange(targetRow, col).getValue() || '').trim();
      var existingYear = String(sh.getRange(targetRow, col + 2).getValue() || '').trim();


      if (existingName === studentName && existingYear === year) {
        targetBlock = { name: col, mobile: col + 1, year: col + 2, desc: col + 3, photo: col + 4 };
        isUpdate = true;
        break;
      }
    }


    // 2. નવી એન્ટ્રી માટે ખાલી બ્લોક
    if (!targetBlock) {
      for (var b = 0; b < startCols.length; b++) {
        var col = startCols[b];
        if (!String(sh.getRange(targetRow, col).getValue() || '').trim()) {
          targetBlock = { name: col, mobile: col + 1, year: col + 2, desc: col + 3, photo: col + 4 };
          break;
        }
      }
    }


    if (!targetBlock) {
      return ContentService.createTextOutput(JSON.stringify({
        status: 'error',
        message: 'બધા બ્લોક્સ ભરાઈ ગયા છે.'
      })).setMimeType(ContentService.MimeType.JSON);
    }


    // ================= ડેટા સેવ =================
    sh.getRange(targetRow, targetBlock.name).setValue(studentName);
    sh.getRange(targetRow, targetBlock.mobile).setValue(inputMobile || '');
    sh.getRange(targetRow, targetBlock.year).setValue(year);
    sh.getRange(targetRow, targetBlock.desc).setValue(description);


    if (photoUrlString) {
      sh.getRange(targetRow, targetBlock.photo).setValue(photoUrlString);
    }


    SpreadsheetApp.flush();


    return ContentService.createTextOutput(JSON.stringify({
      status: 'success',
      message: isUpdate ? 'સિદ્ધિ અપડેટ થઈ ગઈ ✅' : 'નવી સિદ્ધિ સેવ થઈ ગઈ ✅'
    })).setMimeType(ContentService.MimeType.JSON);


  } catch (err) {
    Logger.log('Achievement Save Error: ' + err);
    return ContentService.createTextOutput(JSON.stringify({
      status: 'error',
      message: 'સર્વર ભૂલ: ' + err.toString()
    })).setMimeType(ContentService.MimeType.JSON);
  }
}
