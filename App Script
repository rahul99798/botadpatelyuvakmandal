  /** સભ્ય નંબર મેચ — ટેક્સ્ટ અથવા નંબર (5 vs "5") */
  function sabhyaNoMatches_(cellVal, requested) {
    var a = String(cellVal == null ? '' : cellVal).trim();
    var b = String(requested == null ? '' : requested).trim();
    if (a === b) return true;
    var na = parseFloat(a.replace(/,/g, ''));
    var nb = parseFloat(b.replace(/,/g, ''));
    if (!isNaN(na) && !isNaN(nb) && na === nb) return true;
    return false;
  }


  function findRowBySabhyaNo_(sheet, sabhyaNo) {
    var last = sheet.getLastRow();
    if (last < 2) return null;
    var vals = sheet.getRange(2, SABHYA_COL, last, SABHYA_COL).getValues();
    for (var i = 0; i < vals.length; i++) {
      if (sabhyaNoMatches_(vals[i][0], sabhyaNo)) {
        return i + 2;
      }
    }
    return null;
  }


