  function formatDate(dateRaw) {
    if (!dateRaw) return '';
    var d = new Date(dateRaw);
    if (!isNaN(d.getTime())) {
      var day = ('0' + d.getDate()).slice(-2);
      var month = ('0' + (d.getMonth() + 1)).slice(-2);
      var year = d.getFullYear();
      return day + '-' + month + '-' + year;
    }
    return dateRaw.toString();
  }


