        } catch (trashErr) {}
        return memberPhotoJsonOut_({
          status: 'error',
          message:
            'શીટમાં URL સેવ થયું નથી: ' +
            String(sheetErr) +
            ' (કૉલમ K પ્રોટેક્ટેડ/મર્જ તો નહીં?)',
        });
      }


      return memberPhotoJsonOut_({ status: 'success', photoUrl: photoUrl });
    } catch (driveErr) {
